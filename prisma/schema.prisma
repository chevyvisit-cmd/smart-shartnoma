generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContractStatus {
  PENDING
  SIGNED
  CANCELLED
}

model User {
  id                  String    @id @default(cuid())
  uid                 String?   @unique
  name                String?
  phone               String    @unique
  email               String?   @unique
  pinfl               String?   @unique
  image               String?
  telegramChatId      String?
  freeContractsUsed   Int       @default(0)
  paidContractCredits Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  contracts         Contract[] @relation("Creator")
  receivedContracts Contract[] @relation("Recipient")
  payments          Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  orderId       String   @unique
  amount        Float
  provider      String   // "click" | "payme"
  transactionId String?
  performTime   DateTime?
  status        String   @default("PENDING") // PENDING | SUCCESS | FAILED | CANCELLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contract {
  id              String    @id @default(cuid())
  cid             String?   @unique
  title           String
  content         String
  amount          Float?
  type            String    @default("KONTRAKT") // "KONTRAKT" | "DOGOVOR"
  status          String    @default("PENDING") // PENDING | SENT | ACCEPTED | REJECTED | SIGNED | CANCELLED

  creatorId       String
  creator         User      @relation("Creator", fields: [creatorId], references: [id])

  recipientId     String?
  recipient       User?     @relation("Recipient", fields: [recipientId], references: [id])

  recipientPhone  String?
  recipientPinfl  String?

  terms           String?   @default("[]")

  // Dogovor → Kontrakt parent relation (1-to-many)
  parentId        String?
  parent          Contract?  @relation("DogovorParent", fields: [parentId], references: [id])
  dogovors        Contract[] @relation("DogovorParent")

  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
